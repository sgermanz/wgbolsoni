# URL pública do site (usado em SEO, sitemap, JSON-LD).
# No Railway, defina como Variable: https://seu-projeto.up.railway.app
# Quando apontar o domínio próprio, ajuste para https://wgbolsoni.net
NEXT_PUBLIC_SITE_URL=https://wgbolsoni.net
NEXT_PUBLIC_SERVER_URL=https://wgbolsoni.net

# --- Payload CMS (obrigatório em produção) ---
# Postgres do Railway: copie a "Postgres Connection URL" do serviço Postgres
DATABASE_URI=postgres://user:pass@host:5432/db
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- SMTP (formulário de contato + notificações Payload) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=wgb@wgbolsoni.net
SMTP_FROM_NAME=WG Bolsoni
CONTACT_TO=wgb@wgbolsoni.net

# --- Cloudflare Turnstile (captcha do contato) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# --- Analytics (painel admin) ---
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=https://wgbolsoni.net/
GOOGLE_SERVICE_ACCOUNT_JSON=
